{
  "name": "lumina-note",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "sync-version": "node scripts/sync_version.mjs",
    "prebuild": "node scripts/sync_version.mjs",
    "dev": "electron-vite dev",
    "dev:vite": "vite",
    "dev:cloud": "sh -c 'trap \"kill 0\" EXIT; npm run server:dev & npm run dev:vite'",
    "bundle-node": "node scripts/bundle_node.mjs",
    "opencode:bundle": "node scripts/bundle_opencode.mjs",
    "opencode:smoke": "node scripts/opencode_smoke.mjs",
    "build": "electron-vite build",
    "build:vite": "tsc && vite build",
    "preview": "electron-vite preview",
    "release:prepare": "node scripts/release_prepare.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "server:dev": "cd server && cargo run",
    "server:test": "cd server && cargo test",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:cloud": "sh -c 'npm run test:run -- src/services/cloudSync/client.test.ts src/stores/useCloudSyncStore.test.ts src/components/settings/WebDAVSettings.test.tsx && npm run server:test'",
    "test:e2e:webkit": "WEBKIT_E2E=1 vitest --run src/__tests__/codemirrorSelectAll.webkit.e2e.test.ts",
    "test:repro:flashcard": "vitest --run src/stores/useFlashcardStore.repro.test.ts src/components/flashcard/FlashcardView.repro.test.tsx src/components/flashcard/FlashcardReview.repro.test.tsx src/services/markdown/frontmatter.flashcard.repro.test.ts",
    "test:repro:flashcard:e2e": "FLASHCARD_E2E=1 vitest --run src/__tests__/flashcardReview.chromium.e2e.test.ts",
    "audit:button-tooltips": "node scripts/audit_button_tooltips.mjs",
    "bench": "vitest bench",
    "bench:run": "vitest bench --run"
  },
